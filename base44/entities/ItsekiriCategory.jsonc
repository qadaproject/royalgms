{
  "name": "ItsekiriCategory",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Category name e.g. Lawyers, Doctors"
    },
    "icon": {
      "type": "string",
      "description": "Emoji icon"
    },
    "description": {
      "type": "string"
    },
    "sort_order": {
      "type": "number",
      "default": 0
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name"
  ]
}